; Calculates the binomial coefficient,
; First it calculates the permutations of P(n, k) and P(k, k) then divides them


((cal_binomial ($n $k))
    (, (permutation0 $p $t))
    (O
        (+ (permutation ($n $k)))
        (+ (permutation ($k $k)))
        
        (+ 
            (exec 0 
                (, (permutation0 $p $t)) 
                (, (exec 1 $p $t))
            )
        )
        (+
            (exec 2
                (, (permutation ($n $k) $p1) (permutation ($k $k) $p2))
                (O
                    (pure
                        (cal_binomial ($n $k) $s)
                        $s
                        (i64_to_string (div_i64 (i64_from_string $p1) (i64_from_string $p2)))
                    )
                    (+
                        (exec (6)
                            (, (dbcount $db $dbcount) (countedpattern $pattern $ptrncount) (cal_binomial ($dbcount $ptrncount) $calbin))
                            (, (total_count ($db $pattern) $calbin))
                        )
                    )
                )
            )
        )
    )
)








