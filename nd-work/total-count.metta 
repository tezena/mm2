; Calls the pattern counter and database counter functions
; How it works:
; 1. First counts the number of values in the database and the number of patterns in the expression
; 2. Right after it finishes counting patterns in the expression it uses the values of the counted database values and patterns 
;    and calls the cal_binomial function which calculates the binomial coefficient, (the call to the cal_binomial function is
;    inside the patterncounter or counter function, for consecutiveness)
; 3. After it calculates the binomial coefficient it saves the result, (the code that saves the result is in the cal_binomial 
;    function for consecutiveness reasons)


((total_count $db $pattern)
    (, ((patterncounter $pattern) $p $t) ((dbcounter $db) $pp $tt))
    (, 
        (exec 0 $pp $tt)
        (exec 0 $p $t) 
    )
)